# ============================================================
# Android Production .gitignore
# ============================================================

# Built outputs
/build/
**/build/
*.apk
*.aab
*.apks
*.ap_
*.dex

# Gradle
.gradle/
gradle-wrapper.jar
local.properties

# Android Studio / IntelliJ IDEA
*.iml
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetDropDown.xml
.idea/deploymentTargetSelector.xml
.idea/.name
.idea/gradle.xml
.idea/vcs.xml
captures/

# Native build
.externalNativeBuild/
.cxx/

# Signing & secrets — NEVER commit
*.jks
*.keystore
*.p12
key.properties
keystore.properties

# Firebase / Google services — NEVER commit
google-services.json
GoogleService-Info.plist

# Environment / secrets
*.env
.env.*
secrets.properties
credentials.json

# Test reports & lint output
**/test-results/
**/reports/
lint-results*.xml
lint-results*.html

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
